{
  "manifest_version": 3,
  "name": "Videos Auto Play",
  "version": "1.0.0",
  "description": "自动读取网页剧集列表并在播放结束后连播下一集",
  "permissions": ["tabs", "storage", "scripting", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Videos Auto Play",
    "default_popup": "sidebar/sidebar.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/tab-state.js", "lib/player-play.js", "lib/log-client.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "videos-auto-play@local.dev",
      "strict_min_version": "109.0"
    }
  }
}
